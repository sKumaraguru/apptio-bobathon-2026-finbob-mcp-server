# Azure AD Authentication
CSA_AZURE_TENANT_ID=
CSA_AZURE_CLIENT_ID=
CSA_AZURE_CLIENT_SECRET=

# SharePoint Configuration
CSA_SHAREPOINT_SITE_ID=
CSA_REPORTS_SHAREPOINT_SITES="[{"site_id": "", "site_name": "CSA Site name"}]"

# S3 Cache Configuration (AWS Lambda only)
# S3 bucket for caching SharePoint files across Lambda invocations
# Only required when deploying to AWS Lambda
# Auto-detected when running in Lambda environment
S3_CACHE_BUCKET=

# Backend Service Configuration
BACKEND_SERVICE_PORT=8000
BACKEND_SERVICE_HOST=0.0.0.0

# MCP Server Configuration
MCP_SERVER_PORT=3000
# For local development, use http://localhost:8000
BACKEND_SERVICE_URL=